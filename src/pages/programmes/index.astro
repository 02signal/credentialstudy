---
import Seo from "../../components/Seo.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/global.css";

const plannedAreas = [
  { area: "Data & AI", note: "Practical data skills and applied AI tools for everyday work." },
  { area: "Business & management", note: "Focused skills in project delivery, operations and leadership." },
  { area: "Digital & technology", note: "In-demand digital capabilities for non-developers and specialists." }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "EducationalOrganization", "@id": "https://credentialstudy.com/#org", name: "CredentialStudy", url: "https://credentialstudy.com/" },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://credentialstudy.com/" },
        { "@type": "ListItem", position: 2, name: "Programmes", item: "https://credentialstudy.com/programmes/" }
      ]
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <Seo
      title="Programmes | CredentialStudy"
      description="The first online microcredentials from CredentialStudy are in preparation. See the planned skill areas and get notified when enrolment opens."
      canonicalPath="/programmes/"
      jsonLd={schema}
    />
  </head>
  <body>
    <Nav />
    <main>
      <section class="hero">
        <div class="hero-inner">
          <span class="eyebrow">Programmes · in preparation</span>
          <h1>Focused online microcredentials — opening soon.</h1>
          <p>We're finalising our first programmes. Here are the areas we're starting with. Get notified the moment enrolment opens.</p>
          <div class="actions">
            <a class="btn btn-primary" href="/#notify" data-track-event="cta_click" data-track-label="programmes_notify">Get notified</a>
          </div>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Planned areas</span>
            <h2>Where we're starting.</h2>
          </div>
          <div class="grid-3">
            {plannedAreas.map((p) => (
              <article class="card">
                <span class="tag">Planned</span>
                <h3>{p.area}</h3>
                <p>{p.note}</p>
              </article>
            ))}
          </div>
          <p class="notice" style="margin-top:28px">
            Programme details, prices and enrolment dates will appear here once finalised. Want a say in what we build first?
            <a href="/#notify" data-track-event="cta_click" data-track-label="programmes_interest">Tell us which skill you need</a>.
          </p>
        </div>
      </section>
    </main>
    <Footer label="Programmes" />
  </body>
</html>
